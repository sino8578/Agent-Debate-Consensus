# OpenRouter API key (required for private mode, optional for public mode)
# Get one at https://openrouter.ai/keys
OPENROUTER_API_KEY=

# Deployment mode: "private" (default) or "public"
# - private: server key gives full access to all models
# - public: server key works only for free models; users must enter their own key for paid models and web search
APP_MODE=private

# Maximum number of AI models active simultaneously in one chat (default: 8)
MAX_ACTIVE_MODELS=8
